## Local Development Only
## DO NOT commit this file with real values to git

# Django settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (leave as is for local SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# CSRF trusted origins (for local dev)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://0.0.0.0:8000

## For production on Render:
## DJANGO_DEBUG=False
## DJANGO_SECRET_KEY=<generated automatically by Render>
## DATABASE_URL=<generated automatically by Render from managed PostgreSQL>
## DJANGO_ALLOWED_HOSTS=your-app-name.onrender.com
## DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app-name.onrender.com
